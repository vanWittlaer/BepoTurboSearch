{% sw_extends '@Storefront/storefront/layout/header/search-suggest.html.twig' %}

{% block layout_search_suggest_results %}
    {% set turboTargets = page.getExtension('turboSuggestTargets') %}
    {% set likeProducts = page.getExtension('turboLikeMatchedProducts') %}

    {% if turboTargets and turboTargets|length > 0 %}
        {% block layout_search_suggest_turbo_targets %}
            {% for target in turboTargets %}
                {% block layout_search_suggest_turbo_target_item %}
                    {% if target.categoryId or target.landingPageId or target.productId %}
                        <li class="js-result" role="option">
                            {% if target.categoryId %}
                                {% set targetUrl = seoUrl('frontend.navigation.page', {'navigationId': target.categoryId}) %}
                                {% set targetTitle = target.translated.title ?: (target.category ? target.category.translated.name : '') %}
                            {% elseif target.landingPageId %}
                                {% set targetUrl = seoUrl('frontend.landing.page', {'landingPageId': target.landingPageId}) %}
                                {% set targetTitle = target.translated.title ?: (target.landingPage ? target.landingPage.name : '') %}
                            {% elseif target.productId %}
                                {% set targetUrl = seoUrl('frontend.detail.page', {'productId': target.productId}) %}
                                {% set targetTitle = target.translated.title ?: (target.product ? target.product.translated.name : '') %}
                            {% endif %}
                            <a href="{{ targetUrl }}"
                           class="btn btn-primary w-100 d-flex align-items-center text-start mb-2"
                           title="{{ targetTitle }}">
                            {% block layout_search_suggest_turbo_target_image %}
                                {% if target.media and target.media.url %}
                                    <div class="me-3" style="width: 50px; height: 50px; flex-shrink: 0;">
                                        {% set attributes = {
                                            class: 'rounded',
                                            style: 'width: 50px; height: 50px; object-fit: cover;',
                                            title: (target.media.translated.title ?: ''),
                                            alt: (target.media.translated.alt ?: '')
                                        } %}

                                        {% sw_thumbnails 'turbo-suggest-target-image' with {
                                            media: target.media,
                                            sizes: {
                                                default: '50px'
                                            },
                                            attributes: attributes
                                        } %}
                                    </div>
                                {% endif %}
                            {% endblock %}

                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center">
                                    <div class="fw-bold flex-grow-1">
                                        {{ targetTitle }}
                                    </div>
                                    <div class="ms-3">
                                        {% sw_icon 'arrow-medium-right' style { size: 'sm', pack: 'solid' } %}
                                    </div>
                                </div>
                                {% if target.translated.teaserText %}
                                    <div class="small">
                                        {{ target.translated.teaserText }}
                                    </div>
                                {% endif %}
                            </div>
                            </a>
                        </li>
                    {% endif %}
                {% endblock %}
            {% endfor %}
        {% endblock %}
    {% endif %}

    {% if likeProducts and likeProducts|length > 0 %}
        {% block layout_search_suggest_like_products %}
            {% for product in likeProducts %}
                {% block layout_search_suggest_like_product_item %}
                    <li class="js-result" role="option">
                        <a href="{{ seoUrl('frontend.detail.page', {'productId': product.id}) }}"
                           class="btn btn-primary w-100 d-flex align-items-center text-start mb-2"
                           title="{{ product.translated.name }}">
                            {% block layout_search_suggest_like_product_image %}
                                {% if product.cover and product.cover.media and product.cover.media.url %}
                                    <div class="me-3" style="width: 50px; height: 50px; flex-shrink: 0;">
                                        {% set attributes = {
                                            class: 'rounded',
                                            style: 'width: 50px; height: 50px; object-fit: cover;',
                                            title: (product.cover.media.translated.title ?: ''),
                                            alt: (product.cover.media.translated.alt ?: product.translated.name)
                                        } %}

                                        {% sw_thumbnails 'turbo-suggest-like-product-image' with {
                                            media: product.cover.media,
                                            sizes: {
                                                default: '50px'
                                            },
                                            attributes: attributes
                                        } %}
                                    </div>
                                {% endif %}
                            {% endblock %}

                            <div class="flex-grow-1 overflow-hidden">
                                <div class="d-flex align-items-center">
                                    <div class="fw-bold flex-grow-1 text-truncate">
                                        {{ product.translated.name }}
                                    </div>
                                    <div class="ms-3 flex-shrink-0">
                                        {% sw_icon 'arrow-medium-right' style { size: 'sm', pack: 'solid' } %}
                                    </div>
                                </div>
                                <div class="small text-white-50 d-flex align-items-center justify-content-between">
                                    <span class="flex-shrink-0">
                                        {% set searchTerm = page.searchTerm|default('')|lower %}
                                        {% set productNum = product.productNumber %}
                                        {% set productNumLower = productNum|lower %}
                                        {% set matchPos = productNumLower|u.indexOf(searchTerm) %}

                                        {% if searchTerm and matchPos is not same as(null) and matchPos >= 0 %}
                                            {{ productNum|slice(0, matchPos) }}<span class="text-warning">{{ productNum|slice(matchPos, searchTerm|length) }}</span>{{ productNum|slice(matchPos + searchTerm|length) }}
                                        {% else %}
                                            {{ productNum }}
                                        {% endif %}
                                    </span>
                                    {% block layout_search_suggest_like_product_price %}
                                        {% if product.calculatedPrice %}
                                            <span class="text-nowrap text-end">
                                                {% set price = product.calculatedPrice %}
                                                {% if product.calculatedPrices.count > 0 %}
                                                    {% set price = product.calculatedPrices.last %}
                                                {% endif %}

                                                {% if product.variantListingConfig.displayParent and product.parentId === null %}
                                                    {% set displayFromVariants = price.unitPrice !== product.calculatedCheapestPrice.unitPrice %}
                                                    {% set price = product.calculatedCheapestPrice %}
                                                {% endif %}

                                                {% if product.calculatedPrices.count > 1 or displayFromVariants %}
                                                    {{ 'listing.listingTextFrom'|trans|sw_sanitize }}
                                                {% endif %}
                                                {{ price.unitPrice|currency }}

                                                {% if price.regulationPrice.price is not null %}
                                                    <span class="text-decoration-line-through ms-1">{{ price.regulationPrice.price|currency }}</span>
                                                {% endif %}
                                            </span>
                                        {% endif %}
                                    {% endblock %}
                                </div>
                            </div>
                        </a>
                    </li>
                {% endblock %}
            {% endfor %}
        {% endblock %}
    {% endif %}

    {{ parent() }}
{% endblock %}

{% block layout_search_suggest_result_total %}
    {% set turboTargets = page.getExtension('turboSuggestTargets') %}
    {% set likeProducts = page.getExtension('turboLikeMatchedProducts') %}

    {# Don't show "No results found" if we have turbo targets or like products #}
    {% if not ((turboTargets and turboTargets|length > 0) or (likeProducts and likeProducts|length > 0)) %}
        {{ parent() }}
    {% endif %}
{% endblock %}
